
<div class="container">
    <h1 class="title">bEvent</h1>

    <% if current_user %>
        <div class="user-info">
            <h2>Benvenuto, <%= current_user.email %>!</h2>
            <%= link_to "Modifica Account", edit_user_registration_path, class: "btn" %>
            <%= button_to "Logout", destroy_user_session_path, data: { turbo: "false" }, method: :delete, class: "btn btn-logout" %>
        </div>
    <% else %>
        <h2 class="explore-text">Esplora</h2>
        <div class="actions">
            <%= link_to "Accedi", new_user_session_path, class: "btn btn-login" %>
            <%= link_to "Registrati", new_user_registration_path, class: "btn btn-register" %>
        </div>
    <% end %>
</div>